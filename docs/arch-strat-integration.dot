digraph strat_security_review {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style=filled, shape=box, margin="0.2,0.1"];
    edge [fontname="Helvetica", fontsize=9];
    compound=true;
    newrank=true;

    // Title
    labelloc="t";
    label="Adversarial Review: STRAT Security Integration\n";
    fontsize=16;

    // rfe-creator workspace
    subgraph cluster_rfe {
        label="rfe-creator workspace";
        style="rounded,filled";
        fillcolor="#e8f4fd";
        color="#2196F3";
        fontsize=12;
        fontcolor="#1565C0";

        strat_docs [label="artifacts/strat-tasks/\n(STRAT documents)", fillcolor="#BBDEFB", color="#1565C0"];
        rfe_docs [label="artifacts/rfe-tasks/\n(Source RFEs)", fillcolor="#BBDEFB", color="#1565C0"];
        arch_ctx [label=".context/architecture-context/\n(Platform architecture docs)", fillcolor="#BBDEFB", color="#1565C0"];
        strat_reviews [label="artifacts/strat-reviews/\n{id}-review.md + frontmatter", fillcolor="#C8E6C9", color="#2E7D32"];

        settings [label=".claude/settings.json\nplugins: [adversarial-review]", fillcolor="#FFF9C4", color="#F9A825", shape=note];
    }

    // adversarial-review plugin
    subgraph cluster_ar {
        label="adversarial-review (plugin)";
        style="rounded,filled";
        fillcolor="#FFF3E0";
        color="#FF9800";
        fontsize=12;
        fontcolor="#E65100";

        // Orchestrator
        skill_md [label="SKILL.md\nOrchestrator", fillcolor="#FFE0B2", color="#E65100", shape=octagon];

        // Pipeline phases
        subgraph cluster_pipeline {
            label="Pipeline";
            style="rounded,dashed";
            color="#FF9800";
            fillcolor="#FFF8E1";

            phase0 [label="Phase 0\nCache Init", fillcolor="#FFECB3", color="#FF8F00"];
            phase1 [label="Phase 1\nSelf-Refinement\n(parallel agents, 2-3 iterations)", fillcolor="#FFECB3", color="#FF8F00"];
            phase2 [label="Phase 2\nChallenge Round\n(adversarial debate)", fillcolor="#FFECB3", color="#FF8F00"];
            phase3 [label="Phase 3\nDedup & Ranking", fillcolor="#FFECB3", color="#FF8F00"];
            phase4 [label="Phase 4\nReport", fillcolor="#FFECB3", color="#FF8F00"];

            phase0 -> phase1 -> phase2 -> phase3 -> phase4;
        }

        // STRAT agents
        subgraph cluster_agents {
            label="agents/strat/";
            style="rounded,filled";
            fillcolor="#FCE4EC";
            color="#C62828";
            fontcolor="#B71C1C";

            sec [label="security-analyst.md\nRBAC, auth, data privacy,\nsecrets, API exposure,\nsupply chain", fillcolor="#FFCDD2", color="#C62828"];
            feas [label="feasibility-analyst.md\nBuild viability, effort,\ntechnical approach", fillcolor="#F8BBD0", color="#AD1457"];
            test [label="testability-analyst.md\nAcceptance criteria,\nedge cases, test gaps", fillcolor="#F8BBD0", color="#AD1457"];
            scope [label="scope-analyst.md\nRight-sizing, effort\nalignment, boundaries", fillcolor="#F8BBD0", color="#AD1457"];
            arch [label="architecture-analyst.md\nDependencies, integration,\ncomponent boundaries", fillcolor="#F8BBD0", color="#AD1457"];
        }

        // Profile config
        profile [label="--profile strat\nSelects agent set +\ninput/output conventions", fillcolor="#E1BEE7", color="#6A1B9A", shape=diamond];
    }

    // Flow edges
    settings -> skill_md [label="plugin installed", style=dashed, color="#9E9E9E"];
    skill_md -> profile [label="user invokes\n/adversarial-review\n--profile strat"];
    profile -> phase0;

    strat_docs -> phase0 [label="review target\n(scope files)", color="#1565C0", lhead=cluster_pipeline];
    rfe_docs -> phase0 [label="reference\nmaterial", color="#1565C0", style=dashed];
    arch_ctx -> phase0 [label="reference\nmaterial", color="#1565C0", style=dashed];

    // Agents participate in phases
    {sec, feas, test, scope, arch} -> phase1 [label="", color="#C62828", style=dashed, constraint=false];

    // NEW: security-analyst highlighted
    sec [penwidth=3];

    // Output
    phase4 -> strat_reviews [label="structured findings\nmapped to frontmatter", color="#2E7D32"];

    // Legend
    subgraph cluster_legend {
        label="Legend";
        style="rounded";
        color="#9E9E9E";
        fillcolor="#FAFAFA";
        fontsize=10;

        node [shape=plaintext, fillcolor="#FAFAFA"];
        l1 [label="Bold border = new (security-analyst)\nPink agents = future migration from rfe-creator\nDashed arrows = reference/config"];
    }

    // Demo scope annotation
    demo_note [label="Demo scope (this week):\n1. security-analyst.md agent role\n2. --profile strat mechanism\n3. Plugin install in rfe-creator\n4. Run on real STRAT", shape=note, fillcolor="#FFFDE7", color="#F57F17", fontsize=10];
    demo_note -> sec [style=invis];
}

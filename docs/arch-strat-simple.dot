digraph strat_simple {
    rankdir=LR;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=12, style=filled, margin="0.3,0.15"];
    edge [fontname="Helvetica", fontsize=10];

    labelloc="t";
    label="Adversarial Review: STRAT Security Analysis";
    fontsize=16;

    // Inputs
    strat [label="STRAT\nDocument", shape=note, fillcolor="#BBDEFB", color="#1565C0"];
    rfe [label="Source\nRFE", shape=note, fillcolor="#BBDEFB", color="#1565C0"];

    // Pipeline
    subgraph cluster_pipeline {
        label="adversarial-review plugin";
        style="rounded,filled";
        fillcolor="#FFF3E0";
        color="#FF9800";
        fontsize=12;

        agents [label="Security Analyst\n(parallel agents)", shape=box, fillcolor="#FFCDD2", color="#C62828"];
        refine [label="Self-Refinement\n(2-3 iterations)", shape=box, fillcolor="#FFE0B2", color="#E65100"];
        challenge [label="Adversarial\nChallenge", shape=box, fillcolor="#FFE0B2", color="#E65100"];

        agents -> refine -> challenge;
    }

    // Output
    output [label="Security Risks\n+ Mitigations\nfor the STRAT", shape=box, fillcolor="#C8E6C9", color="#2E7D32", style="filled,rounded"];

    // Flow
    strat -> agents [label="review target"];
    rfe -> agents [label="context", style=dashed];
    challenge -> output;
}
